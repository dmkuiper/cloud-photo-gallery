<%- include('partials/header', { title: 'Upload Photo – Cloud Photo Gallery', username }) %>

<div class="page-wrapper">
  <div class="upload-container">
    <h1>Upload a Photo</h1>
    <p class="subtitle">Accepted: JPEG, PNG, GIF, WebP &mdash; max 10 MB</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success">
        <%= success %>
        <a href="/photos/gallery">View Gallery</a> or upload another below.
      </div>
    <% } %>

    <form
      action="/photos/upload"
      method="POST"
      enctype="multipart/form-data"
      class="upload-form"
      id="uploadForm"
    >
      <!-- Drop zone -->
      <div class="drop-zone" id="dropZone">
        <div class="drop-icon">&#128247;</div>
        <p class="drop-text">Drag &amp; drop an image here, or <label for="photo" class="drop-browse">browse</label></p>
        <input
          type="file"
          id="photo"
          name="photo"
          accept="image/jpeg,image/png,image/gif,image/webp"
          required
          class="drop-input"
        />
        <p class="drop-preview-name" id="fileName">No file chosen</p>
        <img id="previewImg" class="preview-img" src="" alt="" style="display:none;" />
      </div>

      <div class="form-group">
        <label for="title">Title <span class="required">*</span></label>
        <input type="text" id="title" name="title" placeholder="Give your photo a title" required maxlength="255" />
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="Optional description…" maxlength="1000"></textarea>
      </div>

      <div class="form-group">
        <label for="tags">Tags</label>
        <input type="text" id="tags" name="tags" placeholder="nature, travel, sunset (comma-separated)" maxlength="500" />
        <small>Comma-separated tags help you search later.</small>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary" id="submitBtn">
          &#11014; Upload Photo
        </button>
        <a href="/photos/gallery" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
  const dropZone  = document.getElementById('dropZone');
  const fileInput = document.getElementById('photo');
  const fileName  = document.getElementById('fileName');
  const preview   = document.getElementById('previewImg');
  const submitBtn = document.getElementById('submitBtn');

  function handleFile(file) {
    if (!file) return;
    fileName.textContent = file.name;
    const reader = new FileReader();
    reader.onload = e => {
      preview.src = e.target.result;
      preview.style.display = 'block';
    };
    reader.readAsDataURL(file);
  }

  fileInput.addEventListener('change', () => handleFile(fileInput.files[0]));

  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) {
      // Transfer to the real input
      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      handleFile(file);
    }
  });

  document.getElementById('uploadForm').addEventListener('submit', () => {
    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading…';
  });
</script>

<%- include('partials/footer') %>
