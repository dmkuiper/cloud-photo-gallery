<%- include('partials/header', { title: 'My Gallery – Cloud Photo Gallery', username }) %>

<div class="page-wrapper">
  <div class="page-header">
    <h1>My Photos <span class="photo-count">(<%= photos.length %>)</span></h1>

    <!-- Search bar -->
    <form action="/photos/gallery" method="GET" class="search-form">
      <div class="search-group">
        <input
          type="text"
          name="q"
          value="<%= query %>"
          placeholder="Search by title, description, or tags…"
          class="search-input"
        />
        <button type="submit" class="btn btn-search">&#128269; Search</button>
        <% if (query) { %>
          <a href="/photos/gallery" class="btn btn-clear">&#10005; Clear</a>
        <% } %>
      </div>
    </form>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <% if (query && photos.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">&#128269;</div>
      <p>No photos found for &ldquo;<strong><%= query %></strong>&rdquo;.</p>
      <a href="/photos/gallery" class="btn btn-primary">View All Photos</a>
    </div>
  <% } else if (photos.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">&#128247;</div>
      <p>You haven&apos;t uploaded any photos yet.</p>
      <a href="/photos/upload" class="btn btn-primary">Upload Your First Photo</a>
    </div>
  <% } else { %>
    <div class="photo-grid">
      <% photos.forEach(photo => { %>
        <div class="photo-card">
          <div class="photo-img-wrap">
            <img
              src="<%= photo.gcs_url %>"
              alt="<%= photo.title %>"
              class="photo-img"
              loading="lazy"
            />
          </div>
          <div class="photo-info">
            <h3 class="photo-title"><%= photo.title %></h3>

            <% if (photo.description) { %>
              <p class="photo-desc"><%= photo.description %></p>
            <% } %>

            <% if (photo.tags) { %>
              <div class="photo-tags">
                <% photo.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
                  <a href="/photos/gallery?q=<%= encodeURIComponent(tag) %>" class="tag">#<%= tag %></a>
                <% }) %>
              </div>
            <% } %>

            <p class="photo-meta">
              <%= new Date(photo.created_at).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %>
              &bull;
              <%= (photo.file_size / 1024).toFixed(1) %> KB
            </p>

            <div class="photo-actions">
              <a href="/photos/download/<%= photo.id %>" class="btn btn-download">
                &#11123; Download
              </a>
              <form action="/photos/delete/<%= photo.id %>" method="POST"
                    onsubmit="return confirm('Delete this photo?');"
                    style="display:inline;">
                <button type="submit" class="btn btn-delete">&#128465; Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <a href="/photos/upload" class="fab" title="Upload a new photo">+</a>
</div>

<%- include('partials/footer') %>
