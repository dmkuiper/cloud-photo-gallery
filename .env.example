# Database (Google Cloud SQL - MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gallery_user
DB_PASSWORD=your_db_password
DB_NAME=photo_gallery

# For Cloud SQL with Unix socket (used on GCE)
# DB_SOCKET_PATH=/cloudsql/YOUR_PROJECT:YOUR_REGION:YOUR_INSTANCE

# Google Cloud Storage
GCS_BUCKET_NAME=your-photo-gallery-bucket
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Session
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars

# App
PORT=3000
NODE_ENV=production
